<?xml version="1.0"?>
<robot name="dumme" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="is_sim" default="false"/>
  <xacro:arg name="is_ignition" default="true"/>
  <xacro:include filename="$(find dumme_description)/urdf/dumme_ros2_control.xacro"/>
  <xacro:include filename="$(find dumme_description)/urdf/dumme_gazebo.xacro"/>

  <link name="world"/>
  <!-- ================= BASE ================= -->

      <link name="base">
        <inertial>
          <origin xyz="-0.237838794029861 0.00116648759550742 0.0941361596990023" rpy="0 0 0"/>
          <mass value="104.025159848532"/>
          <inertia
            ixx="9.95554955924362"
            ixy="-0.0855188818279365"
            ixz="2.92665042554594"
            iyy="32.8745110413593"
            iyz="0.00595145805780081"
            izz="39.8126602103811"/>
        </inertial>

        <visual>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry>
            <mesh filename="package://dumme_description/meshes/base.STL"/>
          </geometry>
          <material name="grey">
            <color rgba="0.62745 0.62745 0.62745 1"/>
          </material>
        </visual>

        <collision>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry>
            <mesh filename="package://dumme_description/meshes/base.STL"/>
          </geometry>
        </collision>
      </link>
      <joint name="base_joint" type="fixed">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <parent link="world"/>
        <child link="base"/>
      </joint>

      <!-- ================= SHOULDER ROTATION PLATE ================= -->

      <link name="shoulder_rotation_plate">

        <inertial>
          <origin xyz="-0.114528609766886 -0.0537980205800052 0.1190529705771" rpy="0 0 0"/>
          <mass value="98.4948304296841"/>
          <inertia
            ixx="4.05014253551361"
            ixy="-0.10049807307381"
            ixz="-0.0157262861292027"
            iyy="4.18664728849411"
            iyz="-0.00832962607918589"
            izz="6.56714631356963"/>
        </inertial>

        <visual>
          <geometry>
            <mesh filename="package://dumme_description/meshes/shoulder_rotation_plate.STL"/>
          </geometry>
          <material name="grey"/>
        </visual>

        <collision>
          <geometry>
            <mesh filename="package://dumme_description/meshes/shoulder_rotation_plate.STL"/>
          </geometry>
        </collision>

      </link>

      <joint name="shoulder_rotation_plate_joint" type="revolute">

        <origin xyz="-0.53905 0 0.776" rpy="0 0 0"/>

        <parent link="base"/>
        <child link="shoulder_rotation_plate"/>

        <axis xyz="0 0 -1"/>

        <limit
          lower="-3.14159"
          upper="3.14159"
          effort="100"
          velocity="1"/>

      </joint>

      <!-- ================= SHOULDER ================= -->

      <link name="shoulder">

        <inertial>
          <origin xyz="0.78468317632251 0.62021808498562 0.125423994861572" rpy="0 0 0"/>
          <mass value="311.76618623285"/>
          <inertia
            ixx="51.7462517666942"
            ixy="-65.4881067513608"
            ixz="-24.4485941914894"
            iyy="140.425931329383"
            iyz="-13.0135025701085"
            izz="161.872189553428"/>
        </inertial>

        <visual>
          <geometry>
            <mesh filename="package://dumme_description/meshes/shoulder.STL"/>
          </geometry>
          <material name="grey"/>
        </visual>

        <collision>
          <geometry>
            <mesh filename="package://dumme_description/meshes/shoulder.STL"/>
          </geometry>
        </collision>

      </link>

      <joint name="shoulder_joint" type="revolute">

        <origin xyz="0.0015256 -0.20358 0.32475" rpy="0 0 0"/>

        <parent link="shoulder_rotation_plate"/>
        <child link="shoulder"/>

        <axis xyz="0.46808 -0.88369 0"/>

        <limit
          lower="-3.14159"
          upper="3.14159"
          effort="100"
          velocity="1"/>

      </joint>

      <!-- ================= ELBOW ================= -->

      <link name="elbow">

        <inertial>
          <origin xyz="0.186116534540716 -0.0724311046798943 0.0404616434949903" rpy="0 0 0"/>
          <mass value="32.6419905781003"/>
          <inertia
            ixx="0.461129075881471"
            ixy="-0.0127606774751194"
            ixz="-0.0776637736557354"
            iyy="0.490734706844952"
            iyz="-0.0393573814821196"
            izz="0.710990904458108"/>
        </inertial>

        <visual>
          <geometry>
            <mesh filename="package://dumme_description/meshes/elbow.STL"/>
          </geometry>
          <material name="blue"/>
        </visual>

        <collision>
          <geometry>
            <mesh filename="package://dumme_description/meshes/elbow.STL"/>
          </geometry>
        </collision>

      </link>

      <joint name="elbow_joint" type="revolute">

        <origin xyz="1.6881 0.89319 0.59361" rpy="0 0 0"/>

        <parent link="shoulder"/>
        <child link="elbow"/>

        <axis xyz="-0.46808 0.88369 0"/>

        <limit
          lower="-3.14159"
          upper="3.14159"
          effort="100"
          velocity="1"/>

      </joint>

      <!-- ================= WRIST ================= -->

  <link name="wrist">
    <inertial>
        <origin xyz="-0.0839865112096434 0.0107015832173489 0.0759796068528873" rpy="0 0 0"/>
        <mass value="25.9085178719333"/>
        <inertia ixx="0.579147511052588" 
                 ixy="0.089858857026689" 
                 ixz="0.0596188352478989" 
                 iyy="0.414259590699945" 
                 iyz="0.0547716403474197" 
                 izz="0.594475138300998"/>
    </inertial>
    <visual>
        <geometry>
            <mesh filename="package://dumme_description/meshes/wrist.STL"/>
        </geometry>
        <material name="grey"/>
    </visual>
    <collision>
        <geometry>
            <mesh filename="package://dumme_description/meshes/wrist.STL"/>
        </geometry>
    </collision>
  </link>
  <joint name="wrist_joint" type="revolute">
    <origin xyz="1.1496 0.69435 0.41553" rpy="0 0 0"/>
    <parent link="elbow"/>
    <child link="wrist"/>
    <axis xyz="0.47573 -0.87959 0.0026889"/>
    <limit lower="-3.14159" upper="3.14159" effort="100" velocity="1"/>
  </joint>

  <!-- ================= CAMERA MOUNT ================= -->

  <link name="camera_mount">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.20"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <box size="0.05 0.05 0.20"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0"/>
      <inertia
        ixx="0.001"
        ixy="0"
        ixz="0"
        iyy="0.001"
        iyz="0"
        izz="0.001"/>
    </inertial>
  </link>

  <joint name="camera_mount_joint" type="fixed">
    <!-- Adjust this position -->
    <origin xyz="-2.2 0 6.6" rpy="0 0 0"/>
    <parent link="base"/>
    <child link="camera_mount"/>
  </joint>

  <!-- ================= RGB CAMERA ================= -->

  <link name="rgb_camera">
    <visual>
      <geometry>
        <box size="0.08 0.08 0.05"/>
      </geometry>
      <material name="camera">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <box size="0.08 0.08 0.05"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia
        ixx="0.0002"
        ixy="0"
        ixz="0"
        iyy="0.0002"
        iyz="0"
        izz="0.0002"/>
    </inertial>
  </link>

  <joint name="rgb_camera_joint" type="fixed">
    <origin xyz="0 0 0.12" rpy="0 0 0"/>
    <parent link="camera_mount"/>
    <child link="rgb_camera"/>
  </joint>
  <xacro:dumme_ros2_control/>

  <xacro:dumme_gazebo/>
</robot>